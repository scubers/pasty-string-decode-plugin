{
  "schemaVersion": 2,
  "plugin": {
    "id": "plugin.template.full",
    "title": "Template Plugin",
    "version": "0.1.0"
  },
  "install": {
    "runtime": "node",
    "entry": "scripts/install.mjs"
  },
  "runtime": {
    "nodeEntry": "dist/plugin.cjs",
    "uiRoot": "dist/ui"
  },
  "permissions": [
    "setAttachment",
    "setSearchExtension",
    "setTags",
    "setPinned"
  ],
  "attachmentRenderers": [
    {
      "id": "template-renderer",
      "title": "Template Preview",
      "attachmentType": "plugin.template.full.preview",
      "height": 220,
      "uiEntry": "renderers/template-renderer/index.html"
    },
    {
      "id": "template-expanded-renderer",
      "title": "Template Expanded",
      "attachmentType": "plugin.template.full.expanded",
      "height": { "min": 120, "max": 480 },
      "uiEntry": "renderers/template-expanded-renderer/index.html"
    },
    {
      "id": "gallery-renderer-fixed",
      "title": "Gallery (fixed 240)",
      "attachmentType": "plugin.template.full.gallery.fixed",
      "height": 240,
      "uiEntry": "renderers/gallery-renderer-fixed/index.html"
    },
    {
      "id": "gallery-renderer-auto",
      "title": "Gallery (auto)",
      "attachmentType": "plugin.template.full.gallery.auto",
      "height": "auto",
      "uiEntry": "renderers/gallery-renderer-auto/index.html"
    },
    {
      "id": "gallery-renderer-bounded",
      "title": "Gallery (bounded 120-480)",
      "attachmentType": "plugin.template.full.gallery.bounded",
      "height": { "min": 120, "max": 480 },
      "uiEntry": "renderers/gallery-renderer-bounded/index.html"
    }
  ],
  "detectors": [
    {
      "id": "template-detector",
      "title": "Template Detector",
      "supportedInputKinds": ["text", "image", "path_reference"],
      "attachmentTypes": [
        "plugin.template.full.preview",
        "plugin.template.full.expanded"
      ]
    },
    {
      "id": "gallery-detector",
      "title": "Capability Gallery Detector",
      "supportedInputKinds": ["text", "image", "path_reference"],
      "attachmentTypes": [
        "plugin.template.full.gallery.fixed",
        "plugin.template.full.gallery.auto",
        "plugin.template.full.gallery.bounded"
      ]
    }
  ],
  "actions": [
    {
      "id": "template-auto-action",
      "title": "Template Auto Action",
      "supportedItemTypes": ["text", "image", "path_reference"],
      "lifecycle": "auto-run",
      "keywords": ["template", "metadata", "debug"]
    },
    {
      "id": "template-auto-action-text",
      "title": "Template Auto Action (Text)",
      "supportedItemTypes": ["text"],
      "lifecycle": "auto-run",
      "keywords": ["template", "metadata", "debug", "text", "quota"]
    },
    {
      "id": "template-auto-action-image",
      "title": "Template Auto Action (Image)",
      "supportedItemTypes": ["image"],
      "lifecycle": "auto-run",
      "keywords": ["template", "metadata", "debug", "image", "quota"]
    },
    {
      "id": "gallery-auto-text",
      "title": "Gallery Auto (text)",
      "supportedItemTypes": ["text", "image", "path_reference"],
      "lifecycle": "auto-run",
      "keywords": ["gallery", "demo", "showcase", "text"]
    },
    {
      "id": "gallery-auto-image",
      "title": "Gallery Auto (image)",
      "supportedItemTypes": ["image"],
      "lifecycle": "auto-run",
      "keywords": ["gallery", "demo", "showcase", "image"]
    },
    {
      "id": "gallery-auto-none",
      "title": "Gallery Auto (none)",
      "supportedItemTypes": ["text", "image", "path_reference"],
      "lifecycle": "auto-run",
      "keywords": ["gallery", "demo", "showcase", "none"]
    },
    {
      "id": "gallery-draft",
      "title": "Gallery Draft",
      "supportedItemTypes": ["text", "image", "path_reference"],
      "lifecycle": "draft",
      "keywords": ["gallery", "demo", "showcase", "draft"],
      "uiEntry": "actions/gallery-draft/index.html"
    }
  ]
}
