{
  "name": "@pasty/awesome-decode",
  "private": true,
  "version": "0.1.0",
  "description": "Pasty v2 plugin that auto-decodes Base64 / URL / Escaped JSON / JWT clipboard strings into a preview card.",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "dev": "vite --host 127.0.0.1 --open /src/preview/preview-host/index.html",
    "dev:renderer": "vite --host 127.0.0.1 --open /src/preview/preview-host/index.html?view=renderer",
    "build:sdk": "node ./sdk/scripts/build.mjs",
    "build:runtime": "node ./scripts/build-runtime.mjs",
    "build:ui": "node ./scripts/build-ui.mjs",
    "verify:build": "node ./scripts/verify-build.mjs",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "build:artifacts": "npm run clean && npm run build:sdk && npm run build:runtime && npm run build:ui && npm run verify:build",
    "build": "npm run typecheck && npm run lint && npm run build:artifacts",
    "verify": "npm run build && npm test",
    "test": "node --experimental-strip-types --require ./sdk/tests/setup.cjs --test ./tests/**/*.test.cjs"
  },
  "dependencies": {
    "@pasty/plugin-sdk": "file:./sdk",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-vue": "^5.2.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.4",
    "eslint-plugin-vue": "^9.33.0",
    "jsdom": "^25.0.0",
    "vite": "^5.4.14",
    "vue-eslint-parser": "^9.4.3",
    "vue-tsc": "^2.2.12"
  }
}
